defaults:
  cpu: "1"
  memory: "1g"
  disk: "5g"

profiles:
  nunu-bot:
    gateway_port: 8642
    dashboard_port: 9119
    soul: ./souls/default.md
    secret_vars:
      FEISHU_APP_ID: NUNU_BOT_FEISHU_APP_ID
      FEISHU_APP_SECRET: NUNU_BOT_FEISHU_APP_SECRET
  tina-bot:
    gateway_port: 8643
    dashboard_port: 9120
    soul: ./souls/default.md
    secret_vars:
      FEISHU_APP_ID: TINA_BOT_FEISHU_APP_ID
      FEISHU_APP_SECRET: TINA_BOT_FEISHU_APP_SECRET
