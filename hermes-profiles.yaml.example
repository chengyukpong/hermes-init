defaults:
  cpu: "1"
  memory: "1g"
  disk: "5g"

profiles:
  hermes-1:
    gateway_port: 8642
    dashboard_port: 9119
    env:
      FEISHU_APP_ID: your-feishu-app-id
      FEISHU_APP_SECRET: your-feishu-app-secret
  hermes-2:
    gateway_port: 8643
    dashboard_port: 9120
    env:
      FEISHU_APP_ID: your-feishu-app-id
      FEISHU_APP_SECRET: your-feishu-app-secret
